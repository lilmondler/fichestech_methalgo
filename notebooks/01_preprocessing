# DATA LOADING UTILITY

def load_dataset(path: str, name: str):
    """Load a CSV dataset and normalise the created_utc timestamp."""
    # Removed low_memory=False as it's not supported with engine='python'
    df = pd.read_csv(path, engine='python', on_bad_lines='skip')
    df.columns = df.columns.str.strip().str.lower()

    # Debugging: Print columns to check for 'body'
    print(f"[{name}] Columns after processing: {df.columns.tolist()}")

    # Rename 'text' to 'body' if 'text' exists, and 'date' to 'created_utc' if 'date' exists
    if 'text' in df.columns:
        df.rename(columns={'text': 'body'}, inplace=True)
    if 'date' in df.columns:
        df.rename(columns={'date': 'created_utc'}, inplace=True)

    # Parse timestamp — handles both unix integer and ISO string
    if 'created_utc' in df.columns:
        col = df['created_utc']
        if pd.api.types.is_numeric_dtype(col):
            df['created_utc'] = pd.to_datetime(col, unit='s', utc=True)
        else:
            df['created_utc'] = pd.to_datetime(col, utc=True, errors='coerce')

    # Remove deleted / empty posts
    df = df[df['body'].notna()]
    df = df[~df['body'].str.strip().isin(['[deleted]', '[removed]', ''])]
    df['community'] = name

    print(f'[{name}]  {len(df):,} posts  |  {df["author"].nunique():,} unique authors')
    return df


