      "source": [
        "# DATA LOADING UTILITY\n",
        "\n",
        "def load_dataset(path: str, name: str):\n",
        "    \"\"\"Load a CSV dataset and normalise the created_utc timestamp.\"\"\"\n",
        "    # Removed low_memory=False as it's not supported with engine='python'\n",
        "    df = pd.read_csv(path, engine='python', on_bad_lines='skip')\n",
        "    df.columns = df.columns.str.strip().str.lower()\n",
        "\n",
        "    # Debugging: Print columns to check for 'body'\n",
        "    print(f\"[{name}] Columns after processing: {df.columns.tolist()}\")\n",
        "\n",
        "    # Rename 'text' to 'body' if 'text' exists, and 'date' to 'created_utc' if 'date' exists\n",
        "    if 'text' in df.columns:\n",
        "        df.rename(columns={'text': 'body'}, inplace=True)\n",
        "    if 'date' in df.columns:\n",
        "        df.rename(columns={'date': 'created_utc'}, inplace=True)\n",
        "\n",
        "    # Parse timestamp — handles both unix integer and ISO string\n",
        "    if 'created_utc' in df.columns:\n",
        "        col = df['created_utc']\n",
        "        if pd.api.types.is_numeric_dtype(col):\n",
        "            df['created_utc'] = pd.to_datetime(col, unit='s', utc=True)\n",
        "        else:\n",
        "            df['created_utc'] = pd.to_datetime(col, utc=True, errors='coerce')\n",
        "\n",
        "    # Remove deleted / empty posts\n",
        "    df = df[df['body'].notna()]\n",
        "    df = df[~df['body'].str.strip().isin(['[deleted]', '[removed]', ''])]\n",
        "    df['community'] = name\n",
        "\n",
        "    print(f'[{name}]  {len(df):,} posts  |  {df[\"author\"].nunique():,} unique authors')\n",
        "    return df\n",
        "\n",
        "\n",
        "# Load both datasets\n",
        "df_incels  = load_dataset('/Incels.csv',  'incels')\n",
        "df_femcels = load_dataset('/Truefemcels.csv', 'femcels')\n",
        "\n",
        "datasets = {'incels': df_incels, 'femcels': df_femcels}\n",
        "\n",
        "# Quick sanity check\n",
        "df_incels.head(3)\n"
      ],
