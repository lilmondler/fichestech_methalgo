      "source": [
"""
### 1.1 — Text Preprocessing

Le prétraitement des textes comprend plusieurs étapes de nettoyage afin de rendre les corpus plus homogènes et exploitables pour l’analyse NLP.

Le pipeline applique :

- la conversion de tous les textes en minuscules ;
- la suppression des URLs, des références Reddit, de la ponctuation et des chiffres ;
- la suppression des stopwords anglais ainsi que de certains termes parasites liés à la plateforme Reddit ;
- la lemmatisation des mots à l’aide de `WordNetLemmatizer` afin de regrouper différentes formes d’un même terme.
"""
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "c0007",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "c0007",
        "outputId": "0e94e585-4532-44b0-f8a4-34255d3e49ed"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "  Preprocessing text...\n",
            "  Preprocessing text...\n",
            "Sample cleaned post (incels):\n",
            "blogger tarnishedsophia question thatincelblogger\n"
          ]
        }
      ],
      "source": [
        "# Platform-specific noise words to exclude from analysis\n",
        "PLATFORM_NOISE = {\n",
        "    'like','just','people','get','one','would','also','think','even',\n",
        "    'really','know','say','make','good','thing','much','still','reddit',\n",
        "    'post','comment','deleted','removed','amp','gt','http','www','im',\n",
        "    'dont','cant','ive','youre','thats','theyre','its','got','going',\n",
        "}\n",
        "\n",
        "_lemmatizer = WordNetLemmatizer()\n",
        "_stop_words = set(stopwords.words('english')) | PLATFORM_NOISE\n",
        "\n",
        "\n",
        "def clean_text(text: str) -> str:\n",
        "    \"\"\"Full preprocessing pipeline for a single post body.\"\"\"\n",
        "    text = str(text).lower()\n",
        "    text = re.sub(r'http\\S+|www\\S+', ' ', text)\n",
        "    text = re.sub(r'u/\\w+|r/\\w+', ' ', text)\n",
        "    text = re.sub(r'[^a-z\\s]', ' ', text)\n",
        "    text = re.sub(r'\\s+', ' ', text).strip()\n",
        "    tokens = [\n",
        "        _lemmatizer.lemmatize(t)\n",
        "        for t in text.split()\n",
        "        if t not in _stop_words and len(t) > 2\n",
        "    ]\n",
        "    return ' '.join(tokens)\n",
        "\n",
        "\n",
        "def build_corpus(df) -> object:\n",
        "    \"\"\"Apply clean_text to every row of the 'body' column.\"\"\"\n",
        "    print('  Preprocessing text...')\n",
        "    return df['body'].astype(str).apply(clean_text)\n",
        "\n",
        "\n",
        "# Build corpora\n",
        "corpus_incels  = build_corpus(df_incels)\n",
        "corpus_femcels = build_corpus(df_femcels)\n",
        "\n",
        "print('Sample cleaned post (incels):')\n",
        "print(corpus_incels.iloc[0])\n"
      ]
    },
