          ]
        }
      ],
      "source": [
        "# 2.2 — LDA TOPIC MODELING\n",
        "\n",
        "\n",
        "def fit_lda(corpus, name, n_topics=N_TOPICS, max_features=5000):\n",
        "    \"\"\"Fit CountVectorizer + LDA; return results dict.\"\"\"\n",
        "    print(f'  Training LDA for [{name}]  ({n_topics} topics)...')\n",
        "    vectorizer = CountVectorizer(\n",
        "        max_df=0.90, min_df=5,\n",
        "        max_features=max_features,\n",
        "        ngram_range=(1, 2)\n",
        "    )\n",
        "    dtm = vectorizer.fit_transform(corpus)\n",
        "    lda = LatentDirichletAllocation(\n",
        "        n_components=n_topics, max_iter=20,\n",
        "        learning_method='online', random_state=RANDOM_STATE, n_jobs=-1\n",
        "    )\n",
        "    lda.fit(dtm)\n",
        "    vocab = vectorizer.get_feature_names_out()\n",
        "    topics = {}\n",
        "    print(f'\\n  Topics [{name}]:')\n",
        "    for i, comp in enumerate(lda.components_):\n",
        "        top_idx   = comp.argsort()[-N_TOP_WORDS:][::-1]\n",
        "        top_words = [vocab[j] for j in top_idx]\n",
        "        topics[f'Topic {i+1}'] = {'words': top_words, 'weights': comp[top_idx]}\n",
        "        print(f'  Topic {i+1}: {', '.join(top_words)}')\n",
        "    return {'name': name, 'lda': lda, 'vectorizer': vectorizer,\n",
        "            'dtm': dtm, 'vocab': vocab, 'topics': topics}\n",
        "\n",
        "\n",
        "lda_incels  = fit_lda(corpus_incels,  'incels')\n",
        "lda_femcels = fit_lda(corpus_femcels, 'femcels')\n"
      ]
    },
