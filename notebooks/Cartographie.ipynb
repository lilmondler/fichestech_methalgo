      "source": [
        "# 2.1 — TOP-N WORD FREQUENCY\n",
        "\n",
        "def get_top_words(corpus, n=N_FREQ_WORDS):\n",
        "    all_words = ' '.join(corpus).split()\n",
        "    return Counter(all_words)\n",
        "\n",
        "\n",
        "freq_incels  = get_top_words(corpus_incels)\n",
        "freq_femcels = get_top_words(corpus_femcels)\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(16, 7))\n",
        "\n",
        "for ax, (name, freq) in zip(axes, [('incels', freq_incels), ('femcels', freq_femcels)]):\n",
        "    words, counts = zip(*freq.most_common(N_FREQ_WORDS))\n",
        "    ax.barh(words[::-1], counts[::-1], color=PALETTE[name], alpha=0.85, edgecolor='white')\n",
        "    ax.set_title(f'Top {N_FREQ_WORDS} Words — {name.capitalize()}',\n",
        "                 fontsize=14, fontweight='bold', color=PALETTE[name])\n",
        "    ax.set_xlabel('Frequency')\n",
        "    ax.tick_params(axis='y', labelsize=10)\n",
        "\n",
        "fig.suptitle('Vocabulary Comparison: Incels vs. Femcels',\n",
        "             fontsize=16, fontweight='bold', y=1.01)\n",
        "plt.tight_layout()\n",
        "plt.savefig('fig_top_words.png', bbox_inches='tight')\n",
        "plt.show()\n"
      ]
    },
