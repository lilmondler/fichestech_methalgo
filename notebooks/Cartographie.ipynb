      "source": [
        "# 3.1 — BASIC COMMUNITY STATISTICS TABLE\n",
        "\n",
        "\n",
        "rows = []\n",
        "for name, df in datasets.items():\n",
        "    total  = len(df)\n",
        "    unique = df['author'].nunique()\n",
        "    counts = df['author'].value_counts()\n",
        "\n",
        "    def top_share(pct):\n",
        "        n = max(1, int(np.ceil(unique * pct)))\n",
        "        return round(counts.iloc[:n].sum() / total * 100, 1)\n",
        "\n",
        "    rows.append({\n",
        "        'Community'         : name.capitalize(),\n",
        "        'Total posts'       : total,\n",
        "        'Unique authors'    : unique,\n",
        "        'Posts / author'    : round(total / unique, 1),\n",
        "        'Top 1% share (%)'  : top_share(0.01),\n",
        "        'Top 5% share (%)'  : top_share(0.05),\n",
        "        'Top 10% share (%)' : top_share(0.10),\n",
        "    })\n",
        "\n",
        "stats_df = pd.DataFrame(rows).set_index('Community')\n",
        "stats_df\n"
      ]
    },
