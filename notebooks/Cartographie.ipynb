        "# CONFIGURATION\n",
        "\n",
        "\n",
        "INCEL_PATH  = \"sample_data/incels.csv\"   # path to incels dataset\n",
        "FEMCEL_PATH = \"sample_data/Truefemcels.csv\"  # path to femcels dataset\n",
        "\n",
        "# Analysis parameters\n",
        "N_TOPICS      = 5    # number of LDA topics per community\n",
        "N_TOP_WORDS   = 10   # keywords per topic\n",
        "N_FREQ_WORDS  = 20   # top-N words for frequency chart\n",
        "RANDOM_STATE  = 42\n",
        "\n",
        "# Community color palette\n",
        "PALETTE = {\"incels\": \"#d62728\", \"femcels\": \"#9467bd\"}\n"
      ]
    },
