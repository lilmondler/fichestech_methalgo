        "\n",
        "# 3.3 — LOG-LOG DISTRIBUTION  (power-law = hierarchy)\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(13, 5))\n",
        "for ax, (name, df) in zip(axes, datasets.items()):\n",
        "    counts    = df['author'].value_counts()\n",
        "    freq_dist = counts.value_counts().sort_index()\n",
        "    ax.loglog(freq_dist.index, freq_dist.values,\n",
        "              'o', markersize=4, color=PALETTE[name], alpha=0.7)\n",
        "    ax.set_title(f'Posts-per-Author Distribution — {name.capitalize()}',\n",
        "                 fontsize=12, fontweight='bold', color=PALETTE[name])\n",
        "    ax.set_xlabel('Posts per author  (log scale)')\n",
        "    ax.set_ylabel('Number of authors  (log scale)')\n",
        "    ax.grid(True, which='both', linestyle='--', alpha=0.4)\n",
        "\n",
        "fig.suptitle('Log-Log Distribution  |  Straight line ≈ Power law ≈ Strong hierarchy',\n",
        "             fontsize=13, y=1.01)\n",
