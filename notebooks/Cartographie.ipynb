        "# 2.3 — TOPIC VISUALISATION: keyword weights per cluster\n",
        "\n",
        "\n",
        "def plot_topics(lda_result, save_name):\n",
        "    name   = lda_result['name']\n",
        "    topics = lda_result['topics']\n",
        "    color  = PALETTE[name]\n",
        "    fig, axes = plt.subplots(1, N_TOPICS, figsize=(N_TOPICS * 4, 5))\n",
        "    fig.suptitle(f'LDA Topic Clusters — {name.capitalize()}',\n",
        "                 fontsize=15, fontweight='bold', color=color)\n",
        "    for ax, (topic_name, data) in zip(axes, topics.items()):\n",
        "        words   = data['words'][::-1]\n",
        "        weights = data['weights'][::-1]\n",
        "        weights = weights / weights.sum()\n",
        "        ax.barh(words, weights, color=color, alpha=0.8, edgecolor='white')\n",
        "        ax.set_title(topic_name, fontsize=11, fontweight='bold')\n",
        "        ax.set_xlabel('Relative weight')\n",
        "        ax.tick_params(axis='y', labelsize=9)\n",
        "    plt.tight_layout()\n",
        "    plt.savefig(save_name, bbox_inches='tight')\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "plot_topics(lda_incels,  'fig_lda_incels.png')\n",
        "plot_topics(lda_femcels, 'fig_lda_femcels.png')\n"
      ]
    },
